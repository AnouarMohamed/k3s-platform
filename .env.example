# Cluster
K3S_NODE_NAME=ito-k3s-prod-01
K3S_PUBLIC_IP=203.0.113.10
KUBECONFIG=./kubeconfig

# Public hostnames and ACME email are configured in platform/settings.yaml.

# Break-glass local secrets used by make local-secrets.
# The normal production path is SOPS: secrets/production.enc.yaml + make secrets.
MYSQL_ROOT_PASSWORD=replace-with-long-random-value
WORDPRESS_DB_PASSWORD=replace-with-long-random-value
WORDPRESS_ADMIN_USERNAME=replace-with-admin-username
WORDPRESS_ADMIN_PASSWORD=replace-with-long-random-value
WORDPRESS_ADMIN_EMAIL=replace-with-admin-email
SUPERSET_SECRET_KEY=replace-with-long-random-value
SUPERSET_ADMIN_USERNAME=replace-with-admin-username
SUPERSET_ADMIN_FIRSTNAME=replace-with-admin-first-name
SUPERSET_ADMIN_LASTNAME=replace-with-admin-last-name
SUPERSET_ADMIN_EMAIL=replace-with-admin-email
SUPERSET_ADMIN_PASSWORD=replace-with-long-random-value
PASSBOLT_DB_PASSWORD=replace-with-long-random-value
PORTAINER_ADMIN_PASSWORD_HASH='$2y$05$replace-this-with-real-bcrypt-hash'
RESTIC_REPOSITORY=s3:https://s3.example.com/ito-k3s
RESTIC_PASSWORD=replace-with-long-random-value
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
AWS_DEFAULT_REGION=us-east-1
GRAFANA_ADMIN_USER=replace-with-admin-username
GRAFANA_ADMIN_PASSWORD=replace-with-long-random-value
ALERTMANAGER_WEBHOOK_URL=https://hooks.example.com/platform-alerts
