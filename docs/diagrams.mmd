flowchart LR
  swarm["Current Swarm + Nginx"] --> staging["K3s staging"]
  staging --> stateless["First stateless service"]
  stateless --> gitops["GitOps controller"]
  gitops --> stateful["Stateful rehearsal"]
  stateful --> prod["Production decision"]

  swarm -. rollback by DNS .-> stateless
  stateless -. rollback by DNS .-> swarm

