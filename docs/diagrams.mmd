flowchart TB
  subgraph public["Public edge"]
    dns["DNS records"]
    users["Users / administrators"]
    users --> dns
  end

  subgraph k3s["K3s cluster"]
    lb["ServiceLB / public IP"]
    ing["ingress-nginx"]
    cm["cert-manager"]
    issuer["ClusterIssuer staging / production"]

    subgraph apps["apps namespace"]
      wp["WordPress"]
      jenkins["Jenkins"]
      glpi["GLPI"]
      superset["Superset"]
      passbolt["Passbolt"]
      portainer["Portainer"]
      pvc["PVCs"]
    end

    subgraph ops["ops namespace"]
      monitoring["Prometheus / Grafana / Loki"]
    end
  end

  subgraph git["Git controlled desired state"]
    repo["ito-k3s-platform"]
    kust["root kustomization.yaml"]
    docs["docs + runbooks"]
  end

  dns --> lb --> ing --> apps
  cm --> issuer
  cm --> ing
  apps --> pvc
  repo --> kust --> k3s
  repo --> docs

